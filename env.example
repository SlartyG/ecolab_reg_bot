# Токен бота Telegram (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Прокси для Telegram API, если сервер не достучится до api.telegram.org
# (curl вернёт 000). Примеры: http://user:pass@host:8080 или socks5://host:1080
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

# ID Google-таблицы (из URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/...)
# Одна книга с листами «Мероприятия» и «Акселератор»
SPREADSHEET_ID=your_spreadsheet_id_here

# ID админов через запятую (узнать свой ID: @userinfobot). Необязательно — есть значение по умолчанию
# ADMINS_IDS=123456789,987654321

# Юзернейм поддержки (без @), показывается в приветствии. По умолчанию: HSEVorona
# SUPPORT_USERNAME=your_support_username
